# ---- Supabase ----
# Project URL and anon key (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key — SERVER ONLY, never expose to the browser. Used by the sync job.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Airtable ----
# Personal access token with data.records:read on the base
AIRTABLE_TOKEN=patXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=appAzft2IyOUVJ0ZQ
AIRTABLE_TABLE_ID=tblO6El5ATyaaKt5R
# Separate PAT with data.records:write on the base — used ONLY by the student
# resume upload to write the new resume back to Airtable. Kept distinct from the
# read-only token above so the write path is the only thing that can mutate it.
AIRTABLE_WRITE_TOKEN=patYYYYYYYYYYYYYY

# ---- Sync auth ----
# Shared secret Vercel Cron sends as ?secret=... (or Authorization: Bearer) to the sync routes
SYNC_SECRET=generate-a-long-random-string

# ---- App ----
# Public base URL, used to build the OAuth redirect
NEXT_PUBLIC_SITE_URL=http://localhost:3000
